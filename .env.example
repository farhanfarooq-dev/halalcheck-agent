# Copy this file to .env and fill in real values only on your local machine.
# Never commit your real .env file.

APP_ENV=development
APP_NAME=AI-HalalCheck-Agent
APP_VERSION=1.0
DATABASE_PATH=data/halalcheck.db
APP_ACCESS_PASSWORD=

# Optional LLM settings. Leave keys empty for local/demo mode.
LLM_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Product lookup API.
OPENFOODFACTS_BASE_URL=https://world.openfoodfacts.org

# Email is disabled by default. Use draft mode for demos.
# Use EMAIL_MODE=approval only for human-approved Gmail sending.
EMAIL_MODE=draft
GMAIL_SENDER_EMAIL=halalcheckde@gmail.com
GMAIL_CREDENTIALS_PATH=
GMAIL_TOKEN_PATH=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=your_sender_email@example.com
SENDER_DISPLAY_NAME=Your Name
REPLY_TO_EMAIL=your_reply_email@example.com
